<StackPanel x:Class="BIMPlugins.Levels.WPF.MoveLevelView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:local="clr-namespace:BIMPlugins.Levels.WPF"
        d:DataContext="{d:DesignInstance local:MoveLevelViewModel}"
        mc:Ignorable="d" 
        Background="#FFF3D7C0"
        Orientation="Horizontal"
        Height="26"
        d:DesignWidth="1100" >
    <StackPanel.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <materialDesign:CustomColorTheme BaseTheme="Light" PrimaryColor="#f88518" SecondaryColor="#FF0052A5" />
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesign3.Defaults.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </StackPanel.Resources>

    <TextBlock Text="SE Plugins" Margin="10 0 0 0" VerticalAlignment="Center" />
    <Border Width="4" BorderThickness="1 0" Background="Gray" Margin="10 0" />

    <TextBlock Text="Уровень:" VerticalAlignment="Center"/>
    <ComboBox ItemsSource="{Binding Levels}" SelectedItem="{Binding SelectedLevel, UpdateSourceTrigger=PropertyChanged}"
              Width="160" Margin="5 0" VerticalAlignment="Center" Padding="2"
              DisplayMemberPath="Name" />
    <TextBlock Text="Высотная отметка:" VerticalAlignment="Center" Margin="5 0 0 0"/>
    <TextBox Text="{Binding Elevation}" VerticalAlignment="Center" Padding="0 2" Width="80" Margin="5 0 0 0" TextAlignment="Center" />
    <Border Width="4" BorderThickness="1 0" Background="Gray" Margin="10 0" />

    <Button Padding="10 2" VerticalAlignment="Center" Style="{StaticResource MaterialDesignPaperButton}" Height="22"
        Command="{Binding RunCommand}">
        <TextBlock Text="Готово" FontSize="12" FontWeight="DemiBold"/>
    </Button>
    <Button Padding="10 2" Margin="10 0 0 0" VerticalAlignment="Center" Style="{StaticResource MaterialDesignPaperButton}" Height="22"
        Command="{Binding CloseCommand}">
        <TextBlock Text="Отмена" FontSize="12" FontWeight="DemiBold"/>
    </Button>
</StackPanel>
