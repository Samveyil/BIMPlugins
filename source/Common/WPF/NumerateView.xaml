<StackPanel x:Class="BIMPlugins.Common.WPF.NumerateView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:BIMPlugins.Common.WPF"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             d:DataContext="{d:DesignInstance local:NumerateViewModel}"
             mc:Ignorable="d" 
             Background="#FFF3D7C0"
             Orientation="Horizontal"
             Height="26"
             d:DesignWidth="900" >
    <StackPanel.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <materialDesign:CustomColorTheme BaseTheme="Light" PrimaryColor="#f88518" SecondaryColor="#FF0052A5" />
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesign3.Defaults.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </StackPanel.Resources>

    <TextBlock Text="BIMPlugins" Margin="10 0 0 0" VerticalAlignment="Center" />
    <Border Width="4" BorderThickness="1 0" Background="Gray" Margin="10 0" />

    <TextBlock Text="Префикс:" VerticalAlignment="Center" />
    <TextBox Text="{Binding Prefix}" Width="80" Padding="0 2" VerticalAlignment="Center" Margin="5 0" IsEnabled="{Binding IsNotNumbering}"/>
    <TextBlock Text="Стартовый номер:" VerticalAlignment="Center" Margin="5"/>
    <TextBox Text="{Binding Number}" Width="50" Padding="0 2" VerticalAlignment="Center"  TextAlignment="Center" IsEnabled="{Binding IsNotNumbering}" />
    <TextBlock Text="Параметр для нумерации:" VerticalAlignment="Center" Margin="10 0 5 0"/>
    <ComboBox ItemsSource="{Binding Parameters}" SelectedItem="{Binding SelectedParameter}" VerticalAlignment="Center" Width="150" IsEnabled="{Binding IsNotNumbering}"
              DisplayMemberPath="Definition.Name" Padding="2"/>
    <Border Width="4" BorderThickness="1 0" Background="Gray" Margin="10 0" />

    <Button Padding="10 2" VerticalAlignment="Center" Style="{StaticResource MaterialDesignPaperButton}" Height="22"
            Command="{Binding RunCommand}">
        <TextBlock Text="Готово" FontSize="12" FontWeight="DemiBold"/>
    </Button>
    <Button Padding="10 2" Margin="10 0 0 0" VerticalAlignment="Center" Style="{StaticResource MaterialDesignPaperButton}" Height="22"
            Command="{Binding CloseCommand}">
        <TextBlock Text="Закрыть" FontSize="12" FontWeight="DemiBold"/>
    </Button>
</StackPanel>
