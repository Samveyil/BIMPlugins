<StackPanel x:Class="BIMPlugins.Common.WPF.MirrorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:local="clr-namespace:BIMPlugins.Common.WPF"
             d:DataContext="{d:DesignInstance local:MirrorViewModel}"
             mc:Ignorable="d" 
             Background="#FFF3D7C0"
             Orientation="Horizontal"
             Height="26"
             d:DesignWidth="800" >
    <StackPanel.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <materialDesign:CustomColorTheme BaseTheme="Light" PrimaryColor="#f88518" SecondaryColor="#FF0052A5" />
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesign3.Defaults.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </StackPanel.Resources>

    <TextBlock Text="BIMPlugins" Margin="10 0 0 0" VerticalAlignment="Center" />
    <Border Width="4" BorderThickness="1 0" Background="Gray" Margin="10 0" />
    
    <RadioButton Content="Проверка по всей модели" GroupName="Options" VerticalAlignment="Center" Padding="2 0"/>
    <RadioButton Content="Проверка на активном виде" GroupName="Options" VerticalAlignment="Center"
        IsChecked="{Binding CurrentView, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Padding="2 0"
        Margin="10 0 0 0"/>
    <Border Width="4" BorderThickness="1 0" Background="Gray" Margin="10 0" />

    <Button Padding="10 2" VerticalAlignment="Center" Style="{StaticResource MaterialDesignPaperButton}" Height="22"
            Command="{Binding ShowMirroredElementsCommand}">
        <TextBlock Text="Готово" FontSize="12" FontWeight="DemiBold"/>
    </Button>
    <Button Padding="10 2" Margin="10 0 0 0" VerticalAlignment="Center" Style="{StaticResource MaterialDesignPaperButton}" Height="22"
            Command="{Binding CloseCommand}">
        <TextBlock Text="Отмена" FontSize="12" FontWeight="DemiBold"/>
    </Button>
</StackPanel>
