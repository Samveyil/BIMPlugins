<Window x:Class="BIMPlugins.Views.WPF.CropBoxWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:converters="clr-namespace:BIMPlugins.Windows.Converters;assembly=BIMPlugins.Windows"
        xmlns:local="clr-namespace:BIMPlugins.Views.WPF"
        d:DataContext="{d:DesignInstance local:CropBoxViewModel}"
        mc:Ignorable="d"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        Title="Секущий диапазон на 3D" Height="740" Width="782">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <materialDesign:CustomColorTheme BaseTheme="Light" PrimaryColor="#f88518" SecondaryColor="Lime"/>
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesign3.Defaults.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <converters:RevitColorToSolidColorBrushConverter x:Key="RevitColorToBrushConverter" />
            <materialDesign:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        </ResourceDictionary>
    </Window.Resources>
    
    <StackPanel>
        <StackPanel Orientation="Horizontal" Margin="5">
            <Image Source="/BIMPlugins.Windows;component/Resources/search-32.png" Height="20" Width="20" Margin="5 0"/>
            <TextBox Text="{Binding Filter, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="300"
                     materialDesign:TextFieldAssist.HasClearButton="True" materialDesign:HintAssist.Hint="Поиск" />
        </StackPanel>

        <Border BorderBrush="#f88518" BorderThickness="1" Margin="5 10">
            <ListBox ItemsSource="{Binding FilteredItems}" ScrollViewer.VerticalScrollBarVisibility="Visible" Height="610" MaxHeight="610">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition MinWidth="600"/>
                                <ColumnDefinition Width="120"/>
                            </Grid.ColumnDefinitions>

                            <CheckBox IsChecked="{Binding IsSelected}" Content="{Binding ViewName}" Padding="2 0"/>

                            <StackPanel Orientation="Horizontal" Grid.Column="1" HorizontalAlignment="Right">
                                <Rectangle Fill="{Binding Color, Converter={StaticResource RevitColorToBrushConverter}}" Width="20" Height="20"
                                           Margin="5 0 0 0" Visibility="{Binding IsSelected, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                                <Button Width="25" Height="25" Margin="5 0" Style="{StaticResource MaterialDesignFlatButton}" Padding="0"
                                        Visibility="{Binding IsSelected, Converter={StaticResource BooleanToVisibilityConverter}}"
                                        ToolTip="Показать диапазон видимости вида" Command="{Binding SelectCommand}">
                                    <materialDesign:PackIcon Kind="Target" Width="25" Height="25" Foreground="#99000000"/>
                                </Button>

                                <Button Width="22" Height="22" Style="{StaticResource MaterialDesignFlatButton}" Padding="0"
                                        Visibility="{Binding IsSelected, Converter={StaticResource BooleanToVisibilityConverter}}"
                                        ToolTip="3D подрезка по диапазону видимости вида" Command="{Binding SectionBoxCommand}">
                                    <Image Source="/BIMPlugins.Windows;component/Resources/sectionBox-32.png" Width="22" Height="22"/>
                                </Button>

                                <Button Width="25" Height="25" Style="{StaticResource MaterialDesignFlatButton}" Padding="0" Margin="5 0 0 0"
                                        ToolTip="Открыть вид" Command="{Binding OpenViewCommand}">
                                    <materialDesign:PackIcon Kind="OpenInNew" Width="25" Height="25" Foreground="#99000000"/>
                                </Button>
                            </StackPanel>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Border>

        <CheckBox Content="Показать секущую плоскость" IsChecked="{Binding ShowSectionPlane}" Margin="5" Padding="2 0"/>
    </StackPanel>
</Window>
