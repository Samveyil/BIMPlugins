<Window x:Class="BIMPlugins.Views.WPF.ColourFilterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:converters="clr-namespace:BIMPlugins.Windows.Converters;assembly=BIMPlugins.Windows"
        xmlns:local="clr-namespace:BIMPlugins.Views.WPF"
        d:DataContext="{d:DesignInstance local:ColourFilterViewModel}"
        mc:Ignorable="d"
        Title="Цветные фильтры" Height="520" Width="800" WindowStartupLocation="CenterScreen" ResizeMode="NoResize">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <materialDesign:CustomColorTheme BaseTheme="Light" PrimaryColor="#f88518" SecondaryColor="#FF0052A5" />
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesign3.Defaults.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <converters:RevitColorToSolidColorBrushConverter x:Key="RevitColorToBrushConverter" />
        </ResourceDictionary>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="400"/>
            <ColumnDefinition />
        </Grid.ColumnDefinitions>

        <StackPanel>
            <StackPanel Orientation="Horizontal">
                <Image Source="/BIMPlugins.Windows;component/Resources/search-32.png" Height="20" Width="20" Margin="5 0"/>
                <TextBox Text="{Binding Filter, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="80"
                     materialDesign:TextFieldAssist.HasClearButton="True" materialDesign:HintAssist.Hint="Поиск" />

                <CheckBox Content="Скрыть неотмеченные категории" Padding="2 0" Margin="15 0 0 -5" IsChecked="{Binding HideUnchecked}"/>
                <Button Width="25" Height="25" Padding="0" Margin="15 0 0 0" Command="{Binding SelectVisibleCommand}" HorizontalAlignment="Right"
                        Style="{StaticResource MaterialDesignFlatButton}" ToolTip="Выбрать видимые на виде">
                    <materialDesign:PackIcon Kind="EyeOutline" Width="25" Height="25" Foreground="#CC000000"/>
                </Button>
                <Button Width="25" Height="25" Padding="0" Margin="5 0" Command="{Binding ClearSelectionCommand}" HorizontalAlignment="Right"
                        Style="{StaticResource MaterialDesignFlatButton}" ToolTip="Очистить выбор">
                    <materialDesign:PackIcon Kind="Broom" Width="25" Height="25" Foreground="#CC000000"/>
                </Button>
            </StackPanel>

            <Border Margin="5" Padding="0" BorderThickness="1" BorderBrush="#f88518">
                <ListBox ItemsSource="{Binding Categories}" MinHeight="440" MaxHeight="440" Padding="0">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem" BasedOn="{StaticResource MaterialDesignListBoxItem}">
                            <Setter Property="Padding" Value="3 2" />
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <CheckBox Padding="2 0" Content="{Binding Name}" MinWidth="385"
                                          IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                          Command="{Binding DataContext.CategoryCheckedCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                          CommandParameter="{Binding}"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Border>
        </StackPanel>

        <StackPanel Grid.Column="1">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Получить значения:" Margin="5 0 0 0" VerticalAlignment="Center"/>
                <ComboBox ItemsSource="{Binding SelectionOptions}" SelectedItem="{Binding SelectedOption}" Margin="5 0"
                          Style="{StaticResource MaterialDesignOutlinedComboBox}" Padding="5 3" Width="225"/>

                <Button Width="25" Height="25" Padding="0" Margin="5 0 0 0" Command="{Binding SetRandomColorsCommand}" HorizontalAlignment="Right"
                        Style="{StaticResource MaterialDesignFlatButton}" ToolTip="Задать случайные цвета">
                    <materialDesign:PackIcon Kind="PaletteOutline" Width="25" Height="25" Foreground="#CC000000"/>
                </Button>
            </StackPanel>

            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Параметр:" Margin="5 5 0 0" VerticalAlignment="Center"/>
                <ComboBox ItemsSource="{Binding Parameters}" SelectedItem="{Binding SelectedParameterName}" Margin="5 5 5 0"
                          Style="{StaticResource MaterialDesignOutlinedComboBox}" Padding="5 3" Width="310"
                          IsEditable="True" IsTextSearchEnabled="True"
                          materialDesign:HintAssist.Hint="Укажите параметр для фильтрации" materialDesign:HintAssist.IsFloating="False"/>
            </StackPanel>

            <Border Margin="5" Padding="0" BorderThickness="1" BorderBrush="#f88518">
                <ListBox ItemsSource="{Binding Values}" MinHeight="325" MaxHeight="325" Padding="0" ScrollViewer.VerticalScrollBarVisibility="Visible">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem" BasedOn="{StaticResource MaterialDesignListBoxItem}">
                            <Setter Property="Padding" Value="3 1" />
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="315"/>
                                    <ColumnDefinition Width="auto"/>
                                </Grid.ColumnDefinitions>
                                
                                <TextBlock Text="{Binding ValueString}" VerticalAlignment="Center"/>

                                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                                    <Button Width="25" Height="25" Padding="0" ToolTip="Цвет фильтра"
                                            Style="{StaticResource MaterialDesignFlatButton}"
                                            Command="{Binding DataContext.ChangeFilterColorCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                            CommandParameter="{Binding}">
                                        <Rectangle Fill="{Binding Color, Converter={StaticResource RevitColorToBrushConverter}}" Width="20" Height="20"/>
                                    </Button>
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Border>

            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Область раскраски элементов:" Margin="5 0 0 0" VerticalAlignment="Center"/>
                <ComboBox ItemsSource="{Binding ColoringOptions}" SelectedItem="{Binding SelectedColoringOption}" Margin="5 0"
                          Style="{StaticResource MaterialDesignOutlinedComboBox}" Padding="5 3" Width="200"/>
            </StackPanel>
            
            <Button Content="Выполнить" Margin="5 15" Style="{StaticResource MaterialDesignPaperButton}" Command="{Binding RunCommand}"/>
        </StackPanel>
    </Grid>
</Window>
