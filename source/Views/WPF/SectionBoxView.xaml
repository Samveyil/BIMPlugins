<StackPanel x:Class="BIMPlugins.Views.WPF.SectionBoxView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:local="clr-namespace:BIMPlugins.Views.WPF"
             d:DataContext="{d:DesignInstance local:SectionBoxViewModel}"
             mc:Ignorable="d" 
             Background="#FFF3D7C0"
             Orientation="Horizontal"
             Height="26"
             d:DesignWidth="1150" >
    <StackPanel.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <materialDesign:CustomColorTheme BaseTheme="Light" PrimaryColor="#f88518" SecondaryColor="#FF0052A5" />
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesign3.Defaults.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </StackPanel.Resources>

    <TextBlock Text="BIMPlugins" Margin="10 0 0 0" VerticalAlignment="Center" />
    <Border Width="4" BorderThickness="1 0" Background="Gray" Margin="10 0" />
    
    <TextBlock Text="Нижний уровень:" VerticalAlignment="Center" />
    <ComboBox Width="150" Margin="5 0" Padding="2"
              ItemsSource="{Binding Levels}" SelectedItem="{Binding BottomLevel}"/>
    <TextBlock Text="Смещение снизу:" Margin="5 0 0 0" VerticalAlignment="Center" />
    <TextBox Width="50" Margin="5 0 0 0" Padding="0 2" VerticalAlignment="Center" TextAlignment="Center" Text="{Binding BottomOffset}"/>
    <Border Width="4" BorderThickness="1 0" Background="Gray" Margin="10 0" />
    
    <TextBlock Text="Верхний уровень:" VerticalAlignment="Center" />
    <ComboBox Width="150" Margin="5 0" Padding="2"
              ItemsSource="{Binding Levels}" SelectedItem="{Binding TopLevel}"/>
    <TextBlock Text="Смещение сверху:" Margin="10 0 0 0" VerticalAlignment="Center" />
    <TextBox Width="50" Padding="0 2" Margin="10 0 0 0" VerticalAlignment="Center" TextAlignment="Center" Text="{Binding TopOffset}"/>
    <Border Width="4" BorderThickness="1 0" Background="Gray" Margin="10 0" />

    <Button Padding="10 2" VerticalAlignment="Center" Style="{StaticResource MaterialDesignPaperButton}" Height="22"
            Command="{Binding RunCommand}">
        <TextBlock Text="Готово" FontSize="12" FontWeight="DemiBold"/>
    </Button>
    <Button Padding="10 2" Margin="10 0 0 0" VerticalAlignment="Center" Style="{StaticResource MaterialDesignPaperButton}" Height="22"
            Command="{Binding CloseCommand}">
        <TextBlock Text="Закрыть" FontSize="12" FontWeight="DemiBold"/>
    </Button>
</StackPanel>
