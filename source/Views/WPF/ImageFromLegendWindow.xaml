<Window x:Class="BIMPlugins.Views.WPF.ImageFromLegendWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:local="clr-namespace:BIMPlugins.Views.WPF"
        d:DataContext="{d:DesignInstance local:ImageFromLegendViewModel}"
        mc:Ignorable="d"
        Title="Изображения из легенды" Height="450" Width="500" WindowStartupLocation="CenterScreen" ResizeMode="NoResize" SizeToContent="WidthAndHeight">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <materialDesign:CustomColorTheme BaseTheme="Light" PrimaryColor="#f88518" SecondaryColor="Lime"/>
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesign3.Defaults.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <StackPanel>
        <TextBlock Text="Изображения будут сохранены в узле Визуализация Диспетчера проекта" Margin="5" />
        <GroupBox Margin="5">
            <GroupBox.Header>
                <TextBlock Text="Размер" FontWeight="SemiBold" />
            </GroupBox.Header>
            <StackPanel>
                <RadioButton Content="Установить размер" GroupName="zoomType" Padding="2 0"/>
                <StackPanel Orientation="Horizontal" IsEnabled="{Binding FitToPage}">
                    <TextBox Text="{Binding PixelSize}" Width="40" TextAlignment="Center" Margin="5" />
                    <TextBlock Text="пикселей" Margin="0 5" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" IsEnabled="{Binding FitToPage}">
                    <TextBlock Text="Направление:" Margin="5" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    <RadioButton Content="Вертикально" GroupName="fitDirection" Margin="5" Padding="2 0"/>
                    <RadioButton Content="Горизонтально" GroupName="fitDirection" IsChecked="{Binding HorizontalFit}" Margin="5" Padding="2 0"/>
                </StackPanel>
            </StackPanel>
        </GroupBox>
        <GroupBox Margin="5">
            <GroupBox.Header>
                <TextBlock Text="Зумирование" FontWeight="SemiBold" />
            </GroupBox.Header>
            <StackPanel>
                <RadioButton Content="Выполнить зумирование" GroupName="zoomType" IsChecked="{Binding Zoom}" Padding="2 0"/>
                <StackPanel Orientation="Horizontal" IsEnabled="{Binding Zoom}">
                    <TextBox Text="{Binding ZoomNumber}" Width="40" TextAlignment="Center" Margin="5" />
                    <TextBlock Text="процентов фактического размера" Margin="0 5" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" IsEnabled="{Binding Zoom}">
                    <TextBlock Text="Качество растрового изображения:" TextAlignment="Center" Margin="5" HorizontalAlignment="Left"/>
                    <ComboBox ItemsSource="{Binding Resolutions}" SelectedItem="{Binding SelectedResolution}" Width="40" Height="20" Margin=" 0 5"
                              HorizontalContentAlignment="Center"/>
                </StackPanel>
            </StackPanel>
        </GroupBox>
        <Button Content="Выполнить" HorizontalAlignment="Right" Command="{Binding RunCommand}" Margin="5" />
    </StackPanel>
</Window>
