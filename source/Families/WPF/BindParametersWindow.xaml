<Window x:Class="BIMPlugins.Families.WPF.BindParametersWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:local="clr-namespace:BIMPlugins.Families.WPF"
        d:DataContext="{d:DesignInstance local:BindParametersViewModel}"
        mc:Ignorable="d"
        Title="Связать параметры" Height="700" Width="550" WindowStartupLocation="CenterScreen" ResizeMode="NoResize">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <materialDesign:CustomColorTheme BaseTheme="Light" PrimaryColor="#f88518" SecondaryColor="#FF0052A5" />
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesign3.Defaults.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <materialDesign:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        </ResourceDictionary>
    </Window.Resources>

    <StackPanel>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Width="25" Height="25" Padding="0" Margin="0 0 5 0" Command="{Binding BindByNameCommand}" Style="{StaticResource MaterialDesignFlatButton}" ToolTip="Привязать по имени">
                <materialDesign:PackIcon Kind="SwapHorizontalBold" Width="25" Height="25" Foreground="#CC000000"/>
            </Button>
            <Button Width="25" Height="25" Padding="0" Margin="5 0 5 0" Command="{Binding ClearBindingsCommand}" Style="{StaticResource MaterialDesignFlatButton}" ToolTip="Очистить выбор">
                <materialDesign:PackIcon Kind="Broom" Width="25" Height="25" Foreground="#CC000000"/>
            </Button>
        </StackPanel>

        <Border Margin="5" BorderThickness="1" BorderBrush="#f88518">
            <ListView ItemsSource="{Binding Parameters}" materialDesign:ListViewAssist.ListViewItemPadding="0 2" MaxHeight="570" SelectionMode="Single">
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem" BasedOn="{StaticResource MaterialDesignGridViewItem}">
                        <Setter Property="VerticalAlignment" Value="Center" />
                        <Setter Property="VerticalContentAlignment" Value="Center"/>
                        <Setter Property="FontSize" Value="11.5" />
                    </Style>
                </ListView.ItemContainerStyle>
                <ListView.GroupStyle>
                    <GroupStyle>
                        <GroupStyle.HeaderTemplate>
                            <DataTemplate>
                                <Border BorderThickness="1" Padding="2" Margin="0 0 0 0" Background="Gainsboro">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding Path=Name}" FontWeight="DemiBold" FontSize="11.5" Margin="2 0 0 0"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </GroupStyle.HeaderTemplate>
                    </GroupStyle>
                </ListView.GroupStyle>
                <ListView.View>
                    <GridView AllowsColumnReorder="False">
                        <GridView.ColumnHeaderContainerStyle>
                            <Style TargetType="GridViewColumnHeader" BasedOn="{StaticResource {x:Type GridViewColumnHeader}}">
                                <Setter Property="Padding" Value="0 2" />
                                <Setter Property="HorizontalAlignment" Value="Center" />
                                <Setter Property="VerticalAlignment" Value="Center" />
                                <Setter Property="VerticalContentAlignment" Value="Center" />
                            </Style>
                        </GridView.ColumnHeaderContainerStyle>

                        <GridViewColumn Header="Вложенное семейство" Width="220">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <Label Content="t" FontWeight="DemiBold" ToolTip="Параметр типа" Visibility="{Binding ParameterType, Converter={StaticResource BooleanToVisibilityConverter}}"
                                               VerticalAlignment="Center" Margin="0 0 2 0"/>
                                        <TextBlock Text="{Binding Parameter.Definition.Name}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        
                        <GridViewColumn Header="Родительское семейство" Width="274">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <ComboBox ItemsSource="{Binding FamilyParameters}" SelectedItem="{Binding BindParameter}" Style="{StaticResource MaterialDesignOutlinedComboBox}" Padding="5 3"
                                              materialDesign:TextFieldAssist.HasClearButton="True"
                                              materialDesign:HintAssist.Hint="– нет –" materialDesign:HintAssist.IsFloating="False" DisplayMemberPath="Definition.Name" Width="260"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                    </GridView>
                </ListView.View>
            </ListView>
        </Border>

        <Button Grid.Column="1" Content="Выполнить"  Style="{StaticResource MaterialDesignPaperButton}" Command="{Binding RunCommand}" Margin="5 10"/>
    </StackPanel>
</Window>
