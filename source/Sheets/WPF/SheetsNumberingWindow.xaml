<Window x:Class="BIMPlugins.Sheets.WPF.SheetsNumberingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:b="http://schemas.microsoft.com/xaml/behaviors"
        xmlns:converters="clr-namespace:BIMPlugins.ExtStorage.Converters;assembly=BIMPlugins.ExtStorage"
        xmlns:classes="clr-namespace:BIMPlugins.Sheets.Classes"
        xmlns:local="clr-namespace:BIMPlugins.Sheets.WPF"
        d:DataContext="{d:DesignInstance local:SheetsNumberingViewModel}"
        mc:Ignorable="d"
        Title="Нумератор листов" WindowStartupLocation="CenterScreen" ResizeMode="NoResize" Height="800" Width="1100">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <materialDesign:CustomColorTheme BaseTheme="Light" PrimaryColor="#f88518" SecondaryColor="Lime"/>
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesign3.Defaults.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <materialDesign:InvertBooleanConverter x:Key="InvertBooleanConverter" />
            <converters:EscapeUnderscoreConverter x:Key="EscapeUnderscoreConverter" />
            <converters:NullableToBoolConverter x:Key="NullableToBoolConverter" />

            <Style TargetType="TextBox" x:Key="TextBoxWithButtons">
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="TextBox">
                            <Grid>
                                <Border Background="White" BorderThickness="1" BorderBrush="{StaticResource MaterialDesignShadowBrush}" CornerRadius="4" x:Name="MainBorder">
                                    <ScrollViewer x:Name="PART_ContentHost" Margin="5,0,40,0" VerticalAlignment="Center" />
                                </Border>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                    <Button Width="20" Height="20" VerticalAlignment="Center" HorizontalAlignment="Right" Padding="0" Margin="5 0 0 0"
                                            Style="{StaticResource MaterialDesignFlatButton}"
                                            Command="{Binding PlusCommand}" CommandParameter="{Binding Tag, RelativeSource={RelativeSource AncestorType=TextBox}}">
                                        <materialDesign:PackIcon Kind="Plus" Width="20" Height="20" Foreground="Black"/>
                                    </Button>

                                    <Button Width="20" Height="20" VerticalAlignment="Center" HorizontalAlignment="Right" Padding="0" Margin="0 0 2 0"
                                            Style="{StaticResource MaterialDesignFlatButton}"
                                            Command="{Binding MinusCommand}" CommandParameter="{Binding Tag, RelativeSource={RelativeSource AncestorType=TextBox}}">
                                        <materialDesign:PackIcon Kind="Minus" Width="20" Height="20" Foreground="Black"/>
                                    </Button>
                                </StackPanel>
                            </Grid>

                            <ControlTemplate.Triggers>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter TargetName="MainBorder" Property="BorderBrush" Value="#CCCCCC" />
                                    <Setter TargetName="MainBorder" Property="Opacity" Value="0.7" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </ResourceDictionary>
    </Window.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition />
            <ColumnDefinition Width="500"/>
        </Grid.ColumnDefinitions>

        <GroupBox Margin="5" Padding="0">
            <GroupBox.Header>
                <TextBlock Text="Листы" FontWeight="SemiBold" />
            </GroupBox.Header>

            <TreeView ItemsSource="{Binding SheetSections, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Height="710" VerticalAlignment="Top" Padding="0"
                      VirtualizingStackPanel.IsVirtualizing="True" VirtualizingStackPanel.VirtualizationMode="Recycling" Margin="0 5 0 0" MaxHeight="710">
                <b:Interaction.Triggers>
                    <b:EventTrigger EventName="SelectedItemChanged">
                        <b:InvokeCommandAction Command="{Binding TreeItemClickedCommand}" 
                                               CommandParameter="{Binding SelectedItem, RelativeSource={RelativeSource AncestorType=TreeView}}"/>
                    </b:EventTrigger>
                </b:Interaction.Triggers>
                <TreeView.Resources>
                    <Style TargetType="TreeViewItem" BasedOn="{StaticResource {x:Type TreeViewItem}}">
                        <Setter Property="Padding" Value="2"/>
                        <Setter Property="Margin" Value="0"/>
                        <Setter Property="MinHeight" Value="24"/>

                        <Setter Property="IsExpanded" Value="{Binding IsSelected, Mode=OneWay}"/>
                    </Style>

                    <Style TargetType="CheckBox" BasedOn="{StaticResource MaterialDesignCheckBox}">
                        <Setter Property="Margin" Value="0"/>
                        <Setter Property="Padding" Value="2"/>
                    </Style>

                    <HierarchicalDataTemplate DataType="{x:Type classes:GroupItem}" ItemsSource="{Binding Sheets}">
                        <StackPanel Orientation="Horizontal" Height="20" VerticalAlignment="Center">
                            <Label Content="{Binding Name, Converter={StaticResource EscapeUnderscoreConverter}}" VerticalAlignment="Center" Padding="5 0"/>
                        </StackPanel>
                    </HierarchicalDataTemplate>

                    <HierarchicalDataTemplate DataType="{x:Type classes:SheetNumberingItem}">
                        <StackPanel Orientation="Horizontal" Height="20" VerticalAlignment="Center">
                            <materialDesign:PackIcon Kind="AlertOctagonOutline" Width="18" Height="18" VerticalAlignment="Center"
                                                     Visibility="{Binding WarningImageVisibility, UpdateSourceTrigger=PropertyChanged}" Foreground="Red"/>

                            <TextBlock Text="(" Padding="0" VerticalAlignment="Center" FontSize="10"/>
                            <Label Content="{Binding Number, Converter={StaticResource EscapeUnderscoreConverter}}" VerticalAlignment="Center" Padding="0" FontSize="10"
                                   ToolTip="Исходный номер листа"/>
                            <TextBlock Text=")" Padding="0" VerticalAlignment="Center" FontSize="10"  Margin="0 0 5 0"/>

                            <TextBlock Text="(" Padding="0" VerticalAlignment="Center" FontSize="12"/>
                            <Label Content="{Binding NumberToParameter, Converter={StaticResource EscapeUnderscoreConverter}}"
                                   VerticalAlignment="Center" Padding="0" FontSize="12"
                                   ToolTip="Номер листа в выбранный параметр"/>
                            <TextBlock Text=")" Padding="0" VerticalAlignment="Center" FontSize="12" Margin="0 0 5 0"/>

                            <Label Content="{Binding NewNumber, Converter={StaticResource EscapeUnderscoreConverter}}"
                                   VerticalAlignment="Center" Padding="0" FontWeight="SemiBold"/>
                            <Label Content="-" Margin="3 2" Padding="0" VerticalAlignment="Center" />
                            <Label Content="{Binding Name, Converter={StaticResource EscapeUnderscoreConverter}}" VerticalAlignment="Center" Padding="0"/>
                        </StackPanel>
                    </HierarchicalDataTemplate>
                </TreeView.Resources>
            </TreeView>
        </GroupBox>

        <StackPanel Grid.Column="1" Margin="5">
            <GroupBox IsEnabled="{Binding SelectedGroup, Converter={StaticResource NullableToBoolConverter}}" Padding="0">
                <GroupBox.Header>
                    <TextBlock Text="Настройки нумерации" FontWeight="SemiBold" />
                </GroupBox.Header>

                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="5 5 0 0">
                        <RadioButton Content="Пользовательcкая настройка для группы " Padding="2 0" GroupName="NumberingType" IsChecked="{Binding UserSettings}" />
                        <TextBlock Text="{Binding SelectedGroup.Name}" FontWeight="SemiBold" VerticalAlignment="Center" />
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" IsEnabled="{Binding UserSettings, UpdateSourceTrigger=PropertyChanged}">
                        <TextBox Margin="5 10" materialDesign:HintAssist.Hint="Префикс" materialDesign:TextFieldAssist.HasClearButton="True"
                                 Text="{Binding Prefix, UpdateSourceTrigger=PropertyChanged}" Width="60" materialDesign:HintAssist.IsFloating="True"/>
                        <TextBox Text="{Binding StartNumber, UpdateSourceTrigger=PropertyChanged}" Tag="{x:Static local:SheetsNumberingViewModel.StartNumberName}"
                                 Margin="5 10" Width="70" Height="25"
                                 Style="{StaticResource TextBoxWithButtons}" />
                        <TextBox Margin="5 10" materialDesign:HintAssist.Hint="Суффикс" materialDesign:TextFieldAssist.HasClearButton="True"
                                 Text="{Binding Suffix, UpdateSourceTrigger=PropertyChanged}" Width="60" materialDesign:HintAssist.IsFloating="True"/>
                    </StackPanel>

                    <TextBlock TextWrapping="Wrap" Margin="5">
                        <Run Text="Номер листа можно дополнить ведущими нулями. Для этого укажите минимальную длину строки, которая будет представлять номер."/>
                        <LineBreak/>
                        <LineBreak/>
                        <Run Text="Например:" FontWeight="SemiBold"/>
                        <LineBreak/>
                        <Run Text="Если номер листа — 15, а заданная длина — 3, результат будет 015. Чтобы оставить номер без изменений, укажите длину 1."/>
                    </TextBlock>
                    
                    <StackPanel Orientation="Horizontal" IsEnabled="{Binding UserSettings}">
                        <TextBlock Text="Длина номера листа:" Margin="5 0 5 5" VerticalAlignment="Center"/>
                        <TextBox Text="{Binding NumberLength, UpdateSourceTrigger=PropertyChanged}" Tag="{x:Static local:SheetsNumberingViewModel.NumberLengthName}"
                                 Margin="5 0 5 5" Width="65" Height="25"
                                 Style="{StaticResource TextBoxWithButtons}"  HorizontalAlignment="Left"/>
                    </StackPanel>

                    <Separator Background="#f88518"/>

                    <StackPanel Orientation="Horizontal" Margin="5">
                        <RadioButton Content="Увеличить/уменьшить на заданное значение номера листов в группе " Padding="2 0" GroupName="NumberingType" />
                        <TextBlock Text="{Binding SelectedGroup.Name}" FontWeight="SemiBold" VerticalAlignment="Center" />
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" IsEnabled="{Binding UserSettings, Converter={StaticResource InvertBooleanConverter}}">
                        <ComboBox ItemsSource="{Binding WaysToChangeNumber}" SelectedItem="{Binding SelectedWayToChangeNumber, UpdateSourceTrigger=PropertyChanged}"
                                  Width="100" Margin="5 0 5 5" Height="25"/>
                        <TextBox Text="{Binding Step, UpdateSourceTrigger=PropertyChanged}" Tag="{x:Static local:SheetsNumberingViewModel.StepName}"
                                 Margin="5 0 5 5" Width="70" Height="25"
                                 Style="{StaticResource TextBoxWithButtons}" />
                    </StackPanel>

                    <Separator Background="#f88518"/>

                    <StackPanel Orientation="Horizontal">
                        <CheckBox Content="Записать значение части номера в параметр" Margin="5" Padding="2 0" IsChecked="{Binding WriteNumberToParameter}"/>
                        <ComboBox IsEnabled="{Binding WriteNumberToParameter}"
                                  ItemsSource="{Binding Parameters}" SelectedItem="{Binding SelectedParameter, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                  Margin="0 5" DisplayMemberPath="Definition.Name" materialDesign:HintAssist.Hint="Выберите параметр" Width="200"
                                  IsEditable="True" IsTextSearchEnabled="True" PreviewTextInput="ComboBox_PreviewTextInput" />
                    </StackPanel>
                </StackPanel>
            </GroupBox>

            <Button Content="Выполнить" Command="{Binding RunCommand}"  Style="{StaticResource MaterialDesignPaperButton}"
                    Margin="0 10" VerticalAlignment="Bottom" IsEnabled="{Binding SelectedGroup, Converter={StaticResource NullableToBoolConverter}}" />
        </StackPanel>
    </Grid>
</Window>
