<Window x:Class="BIMPlugins.Sheets.WPF.CopySheetsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:converters="clr-namespace:BIMPlugins.ExtStorage.Converters;assembly=BIMPlugins.ExtStorage"
        xmlns:classes="clr-namespace:BIMPlugins.Sheets.Classes"
        xmlns:local="clr-namespace:BIMPlugins.Sheets.WPF"
        d:DataContext="{d:DesignInstance local:CopySheetsViewModel}"
        mc:Ignorable="d"
        Title="Дубликатор листов" WindowStartupLocation="CenterScreen" ResizeMode="NoResize" Height="800" Width="1130">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <materialDesign:CustomColorTheme BaseTheme="Light" PrimaryColor="#f88518" SecondaryColor="Lime"/>
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesign3.Defaults.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <converters:ViewDuplicateOptionToStringConverter x:Key="ViewDuplicateOptionConverter"/>
            <converters:EscapeUnderscoreConverter x:Key="EscapeUnderscoreConverter" />

            <Style TargetType="TextBox" x:Key="TextBoxWithButtons">
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="TextBox">
                            <Grid>
                                <Border Background="White" BorderThickness="1" BorderBrush="{StaticResource MaterialDesignShadowBrush}" CornerRadius="4" x:Name="MainBorder">
                                    <ScrollViewer x:Name="PART_ContentHost" Margin="5,0,40,0" VerticalAlignment="Center" />
                                </Border>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                    <Button Width="20" Height="20" VerticalAlignment="Center" HorizontalAlignment="Right" Padding="0" Margin="5 0 0 0"
                                Style="{StaticResource MaterialDesignFlatButton}"
                                Command="{Binding PlusCommand}">
                                        <materialDesign:PackIcon Kind="Plus" Width="20" Height="20" Foreground="Black"/>
                                    </Button>

                                    <Button Width="20" Height="20" VerticalAlignment="Center" HorizontalAlignment="Right" Padding="0" Margin="0 0 2 0"
                                Style="{StaticResource MaterialDesignFlatButton}"
                                Command="{Binding MinusCommand}">
                                        <materialDesign:PackIcon Kind="Minus" Width="20" Height="20" Foreground="Black"/>
                                    </Button>
                                </StackPanel>
                            </Grid>

                            <ControlTemplate.Triggers>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter TargetName="MainBorder" Property="BorderBrush" Value="#CCCCCC" />
                                    <Setter TargetName="MainBorder" Property="Opacity" Value="0.7" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </ResourceDictionary>
    </Window.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="650"/>
            <ColumnDefinition />
        </Grid.ColumnDefinitions>

        <GroupBox Margin="5" Padding="0">
            <GroupBox.Header>
                <TextBlock Text="Листы" FontWeight="SemiBold" />
            </GroupBox.Header>

            <StackPanel>
                <StackPanel Orientation="Horizontal">
                    <Image Source="/BIMPlugins.ExtStorage;component/Resources/search-32.png" Height="20" Width="20" Margin="5 7 5 0"/>
                    <TextBox Text="{Binding Filter, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="300"
                             materialDesign:TextFieldAssist.HasClearButton="True" materialDesign:HintAssist.Hint="Поиск" />
                </StackPanel>

                <TreeView ItemsSource="{Binding SheetGroups, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Height="680" Padding="0"
                          VirtualizingStackPanel.IsVirtualizing="True" VirtualizingStackPanel.VirtualizationMode="Recycling" Margin="0 10" MaxHeight="680" >
                    <TreeView.Resources>
                        <Style TargetType="TreeViewItem" BasedOn="{StaticResource MaterialDesignTreeViewItem}">
                            <Setter Property="Padding" Value="2"/>
                            <Setter Property="Margin" Value="0"/>
                            <Setter Property="MinHeight" Value="24"/>

                            <Setter Property="materialDesign:TreeViewAssist.ShowSelection" Value="False"/>
                        </Style>

                        <Style TargetType="CheckBox" BasedOn="{StaticResource MaterialDesignCheckBox}">
                            <Setter Property="Margin" Value="0"/>
                            <Setter Property="Padding" Value="2"/>
                        </Style>

                        <HierarchicalDataTemplate DataType="{x:Type classes:GroupItem}" ItemsSource="{Binding Sheets}">
                            <CheckBox Content="{Binding Name, Converter={StaticResource EscapeUnderscoreConverter}}"
                                      IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Padding="2 0"/>
                        </HierarchicalDataTemplate>

                        <HierarchicalDataTemplate DataType="{x:Type classes:SheetCopyItem}" ItemsSource="{Binding ViewItems}">
                            <StackPanel Orientation="Horizontal">
                                <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                                <TextBox Text="{Binding CopiesAmount, UpdateSourceTrigger=PropertyChanged}" Margin="5 10" Width="70" Height="25"
                                         Style="{StaticResource TextBoxWithButtons}" />

                                <StackPanel>
                                    <TextBlock Text="{Binding Title, Converter={StaticResource EscapeUnderscoreConverter}}" FontWeight="SemiBold"/>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Имя копии:" VerticalAlignment="Center"/>
                                        <TextBox Margin="5,0,0,0" VerticalAlignment="Center" Width="380" HorizontalAlignment="Left" 
                                                 Text="{Binding NewCopyName, UpdateSourceTrigger=PropertyChanged}"/>
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>
                        </HierarchicalDataTemplate>

                        <HierarchicalDataTemplate DataType="{x:Type classes:ViewItem}">
                            <StackPanel Orientation="Horizontal">
                                <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                          Content="{Binding Name, Converter={StaticResource EscapeUnderscoreConverter}}" Padding="2 0"/>
                            </StackPanel>
                        </HierarchicalDataTemplate>
                    </TreeView.Resources>
                </TreeView>
            </StackPanel>
        </GroupBox>

        <StackPanel Grid.Column="1" Margin="5">
            <GroupBox>
                <GroupBox.Header>
                    <TextBlock Text="Общие настройки дублирования" FontWeight="SemiBold" />
                </GroupBox.Header>

                <StackPanel>
                    <TextBlock Text="Дублировать содержимое листов:" FontWeight="SemiBold" />

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition />
                            <ColumnDefinition />
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <CheckBox IsChecked="{Binding IsCopyingViews}" Content="Виды" Padding="2 0" Margin="5"/>
                            <CheckBox IsChecked="{Binding IsCopyingSchedules}" Content="Спецификации" Padding="2 0" Margin="5"/>
                            <CheckBox IsChecked="{Binding IsCopyingLegends}" Content="Легенды" Padding="2 0" Margin="5"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1">
                            <CheckBox IsChecked="{Binding IsCopyingTextNotes}" Content="Текст" Padding="2 0" Margin="5"/>
                            <CheckBox IsChecked="{Binding IsCopyingAnnotations}" Content="Типовые аннотации" Padding="2 0" Margin="5"/>
                            <CheckBox IsChecked="{Binding IsCopyingLines}" Content="Линии детализации" Padding="2 0" Margin="5"/>
                        </StackPanel>
                    </Grid>

                    <Separator Margin=" -10 5" Background="#f88518"/>

                    <TextBlock Text="Дополнительно:" FontWeight="SemiBold" />

                    <StackPanel Orientation="Horizontal">
                        <CheckBox IsChecked="{Binding IsMakingCopiesForSchedules}" IsEnabled="{Binding IsCopyingSchedules}" Content="Создать копии спецификаций"
                                  Padding="2 0" Margin="5"/>
                        <CheckBox IsChecked="{Binding IsMakingCopiesForLegends}" IsEnabled="{Binding IsCopyingLegends}" Content="Создать копии легенд"
                                  Padding="2 0" Margin="10 5 5 5"/>
                    </StackPanel>

                    <Separator Margin=" -10 5" Background="#f88518"/>

                    <TextBlock Text="Нумерация:" FontWeight="SemiBold" />
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="При формировании нового номера&#x0a;добавлять нумерация в" Margin="0 5 5 5"/>
                        <ComboBox Margin="25 5 5 5" Width="205" VerticalAlignment="Center"
                                  ItemsSource="{Binding NumberPositions}" SelectedItem="{Binding SelectedNumberPosition}"/>
                    </StackPanel>

                </StackPanel>
            </GroupBox>

            <GroupBox Margin="0 10 0 0">
                <GroupBox.Header>
                    <TextBlock Text="Настройки дублирования листов" FontWeight="SemiBold" />
                </GroupBox.Header>

                <StackPanel>
                    <CheckBox IsChecked="{Binding IsCopyingTitleBlockParameters}" Content="Копировать значения параметров основной надписи"
                              Padding="2 0" Margin="5 0 0 5"/>
                    
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="auto"/>
                            <ColumnDefinition Width="auto"/>
                            <ColumnDefinition Width="auto"/>
                        </Grid.ColumnDefinitions>

                        <Grid.RowDefinitions>
                            <RowDefinition/>
                            <RowDefinition/>
                        </Grid.RowDefinitions>

                        <TextBox materialDesign:HintAssist.Hint="Префикс номера" materialDesign:TextFieldAssist.HasClearButton="True"
                                 materialDesign:HintAssist.IsFloating="True" Margin="0 5 0 0"
                                 HorizontalAlignment="Left" Text="{Binding NumberPrefix}" Width="190"/>
                        <TextBox Grid.Row="1" Margin="0 10 0 0" materialDesign:HintAssist.Hint="Префикс имени" materialDesign:TextFieldAssist.HasClearButton="True"
                                 materialDesign:HintAssist.IsFloating="True"
                                 HorizontalAlignment="Left" Text="{Binding NamePrefix}" Width="190"/>

                        <TextBlock Grid.Column="1" Text="Номер" Margin="10 5 10 0" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1" Grid.Row="1" Text="Имя" Margin="10 10 10 0" HorizontalAlignment="Center" VerticalAlignment="Center"/>

                        <TextBox Grid.Column="2" materialDesign:HintAssist.Hint="Суффикс номера" materialDesign:TextFieldAssist.HasClearButton="True"
                                 materialDesign:HintAssist.IsFloating="True" Margin="0 5 0 0"
                                 HorizontalAlignment="Left" Text="{Binding NumberSuffix}" Width="190"/>
                        <TextBox Grid.Column="2" Grid.Row="1" Margin="0 10 0 0" materialDesign:TextFieldAssist.HasClearButton="True"
                                 materialDesign:HintAssist.Hint="Суффикс имени"  materialDesign:HintAssist.IsFloating="True"
                                 HorizontalAlignment="Left" Text="{Binding NameSuffix}" Width="190"/>
                    </Grid>
                </StackPanel>
            </GroupBox>

            <GroupBox Margin="0 10">
                <GroupBox.Header>
                    <TextBlock Text="Настройки дублирования видов" FontWeight="SemiBold" />
                </GroupBox.Header>

                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Копирование вида:" VerticalAlignment="Center"/>
                        <ComboBox Margin="60 0 0 0" Width="265" VerticalAlignment="Center" ItemsSource="{Binding ViewDuplicateOptions}"
                                  SelectedItem="{Binding SelectedViewDuplicateOption, Converter={StaticResource ViewDuplicateOptionConverter}, Mode=TwoWay}"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" IsEnabled="{Binding IsSelectedAsDependent}">
                        <CheckBox Content="Обрезать вид" IsChecked="{Binding CropBoxActive}" Margin="5" Padding="2 0" />
                        <CheckBox Content="Показать границу обрезки" IsChecked="{Binding CropBoxVisible}" Margin="5" Padding="2 0" />
                        <CheckBox Content="Обрезать аннотации" IsChecked="{Binding CropAnnotation}" Margin="5" Padding="2 0" />
                    </StackPanel>
                </StackPanel>
            </GroupBox>

            <Button Content="Выполнить" Command="{Binding RunCommand}" Style="{StaticResource MaterialDesignPaperButton}" Margin="0 10" VerticalAlignment="Bottom" />
        </StackPanel>
    </Grid>
</Window>
