<Window x:Class="BIMPlugins.Sheets.WPF.SpecificationScheduleWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:b="http://schemas.microsoft.com/xaml/behaviors"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:converters="clr-namespace:BIMPlugins.ExtStorage.Converters;assembly=BIMPlugins.ExtStorage"
        xmlns:classes="clr-namespace:BIMPlugins.Sheets.Classes"
        xmlns:local="clr-namespace:BIMPlugins.Sheets.WPF"
        d:DataContext="{d:DesignInstance local:SpecificationScheduleViewModel}"
        mc:Ignorable="d"
        Title="Ведомость спецификаций" Height="820" Width="1400" WindowStartupLocation="CenterScreen" ResizeMode="NoResize">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <materialDesign:CustomColorTheme BaseTheme="Light" PrimaryColor="#f88518" SecondaryColor="#FF0052A5" />
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesign3.Defaults.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <materialDesign:InvertBooleanConverter x:Key="InvertBooleanConverter" />
            <converters:EscapeUnderscoreConverter x:Key="EscapeUnderscoreConverter" />
        </ResourceDictionary>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="550"/>
            <ColumnDefinition />
        </Grid.ColumnDefinitions>

        <GroupBox Margin="5 0 5 5" Padding="0">
            <GroupBox.Header>
                <TextBlock Text="Листы со спецификациями" FontWeight="SemiBold" />
            </GroupBox.Header>

            <StackPanel>
                <StackPanel Orientation="Horizontal">
                    <Image Source="/BIMPlugins.ExtStorage;component/Resources/search-32.png" Height="20" Width="20" Margin="5 7 5 0"/>
                    <TextBox Text="{Binding Filter, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="300"
                             materialDesign:TextFieldAssist.HasClearButton="True" materialDesign:HintAssist.Hint="Поиск" />
                </StackPanel>
                <TreeView ItemsSource="{Binding SheetGroups, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Height="705" Padding="0"
                          VirtualizingStackPanel.IsVirtualizing="True" VirtualizingStackPanel.VirtualizationMode="Recycling"
                          Margin="0 10" MaxHeight="705" >
                    <TreeView.Resources>
                        <Style TargetType="TreeViewItem" BasedOn="{StaticResource MaterialDesignTreeViewItem}">
                            <Setter Property="Padding" Value="2"/>
                            <Setter Property="Margin" Value="0"/>
                            <Setter Property="MinHeight" Value="24"/>

                            <Setter Property="materialDesign:TreeViewAssist.ShowSelection" Value="False"/>
                        </Style>

                        <Style TargetType="CheckBox" BasedOn="{StaticResource MaterialDesignCheckBox}">
                            <Setter Property="Margin" Value="0"/>
                            <Setter Property="Padding" Value="2"/>
                        </Style>

                        <HierarchicalDataTemplate DataType="{x:Type classes:GroupItem}" ItemsSource="{Binding Sheets}">
                            <CheckBox Content="{Binding Name, Converter={StaticResource EscapeUnderscoreConverter}}"
                                      IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                      Padding="2 0"/>
                        </HierarchicalDataTemplate>

                        <HierarchicalDataTemplate DataType="{x:Type classes:SheetScheduleItem}" ItemsSource="{Binding ScheduleItems}">
                            <StackPanel Orientation="Horizontal">
                                <CheckBox Content="{Binding Title, Converter={StaticResource EscapeUnderscoreConverter}}"
                                          IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                          Padding="2 0"/>
                            </StackPanel>
                        </HierarchicalDataTemplate>

                        <HierarchicalDataTemplate DataType="{x:Type classes:ScheduleItem}">
                            <StackPanel Orientation="Horizontal">
                                <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                          Content="{Binding Name, Converter={StaticResource EscapeUnderscoreConverter}}" Padding="2 0"/>
                            </StackPanel>
                        </HierarchicalDataTemplate>
                    </TreeView.Resources>
                </TreeView>
            </StackPanel>
        </GroupBox>

        <StackPanel Grid.Column="1">
            <GroupBox Margin="5 0 5 5" Padding="0">
                <GroupBox.Header>
                    <TextBlock Text="Настройки" FontWeight="SemiBold" />
                </GroupBox.Header>

                <StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="auto"/>
                            <ColumnDefinition />
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <StackPanel HorizontalAlignment="Left">
                                <TextBox Text="{Binding NewSpecificationName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         Width="300" Margin="5 10 5 0" Padding="5"
                                         IsEnabled="{Binding RefreshExistOne, Converter={StaticResource InvertBooleanConverter}}"
                                         Style="{StaticResource MaterialDesignOutlinedTextBox}" materialDesign:TextFieldAssist.PrefixText="SE Plugins_"
                                         materialDesign:TextFieldAssist.HasClearButton="True" materialDesign:HintAssist.FloatingOffset="5 -15"
                                         materialDesign:HintAssist.HintPaddingBrush="White" materialDesign:HintAssist.FloatingScale="0.95"
                                         materialDesign:HintAssist.IsFloating="True" materialDesign:HintAssist.Hint="Имя новой ведомости" />
                                <CheckBox Content="Обновить ведомость" IsChecked="{Binding RefreshExistOne}" Padding="2 0" Margin="5 10 0 0"/>
                                <ComboBox ItemsSource="{Binding CreatedSpecifications}" SelectedItem="{Binding SelectedSpecification}" 
                                          Style="{StaticResource MaterialDesignOutlinedComboBox}" Width="300" Margin="5 5 5 5" Padding="5"
                                          HorizontalAlignment="Left" IsEnabled="{Binding RefreshExistOne}" DisplayMemberPath="Name"
                                          materialDesign:HintAssist.Hint="Выберите существующую ведомость" materialDesign:HintAssist.IsFloating="False"/>
                            </StackPanel>

                            <CheckBox Content="Поиск заголовка спецификации" IsChecked="{Binding UseTitle}" Padding="2 0" Margin="5"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Margin="5 0 0 0">
                            <StackPanel Orientation="Horizontal">
                                <ComboBox ItemsSource="{Binding SheetParameters}" SelectedItem="{Binding SelectedSheetNumberParameter}" 
                                          Style="{StaticResource MaterialDesignOutlinedComboBox}" Margin="0 10 5 0" Padding="5" Width="280"
                                          DisplayMemberPath="Definition.Name" materialDesign:HintAssist.Hint="Параметр номера листа"
                                          materialDesign:HintAssist.FloatingOffset="5 -15" materialDesign:HintAssist.HintPaddingBrush="White"
                                          materialDesign:HintAssist.FloatingScale="0.95"/>
                                <ComboBox ItemsSource="{Binding FontNames}" SelectedItem="{Binding SelectedFontName}"
                                          IsEnabled="{Binding RefreshExistOne, Converter={StaticResource InvertBooleanConverter}}"
                                          Style="{StaticResource MaterialDesignOutlinedComboBox}" Margin="5 10 5 0" Padding="5" Width="120"
                                          materialDesign:HintAssist.Hint="Шрифт" materialDesign:HintAssist.FloatingScale="0.95"
                                          materialDesign:HintAssist.FloatingOffset="5 -15" materialDesign:HintAssist.HintPaddingBrush="White"/>
                                <CheckBox Content="Курсив" Padding="2 0" Margin="0 10 5 0" IsChecked="{Binding IsItalic}"
                                          IsEnabled="{Binding RefreshExistOne, Converter={StaticResource InvertBooleanConverter}}"/>
                            </StackPanel>
                            
                            <CheckBox Content="Использовать файл Excel" IsChecked="{Binding UseExcel}" Padding="2 0" Margin="0 10 0 0"/>
                            <Button IsEnabled="{Binding UseExcel}" Content="Выбрать" Style="{StaticResource MaterialDesignFlatButton}"
                                    HorizontalAlignment="Right" Padding="5 0" Height="25" FontSize="12" Margin="0 -20 0 0"
                                    Command="{Binding SelectExcelFileCommand}"/>
                            <TextBox IsEnabled="{Binding UseExcel}" Text="{Binding ExcelFilePath}" Margin="0 0 5 5" Padding="5" IsReadOnly="True"
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                     materialDesign:HintAssist.IsFloating="False" materialDesign:HintAssist.Hint="Путь до файла" />
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </GroupBox>

            <Button Content="Отсортировать" Style="{StaticResource MaterialDesignFlatButton}" ToolTip="Сортировка ведомости спецификаций"
                    HorizontalAlignment="Right" Padding="5 0" Height="25" FontSize="12" Margin="0 -10 0 0"
                    Command="{Binding SortCommand}"/>
            <GroupBox Margin="5 0 5 10" Padding="0">
                <GroupBox.Header>
                    <TextBlock Text="Ведомость спецификаций" FontWeight="SemiBold" />
                </GroupBox.Header>

                <DataGrid ItemsSource="{Binding SpecificationItems}" MinHeight="500" MaxHeight="500" ScrollViewer.VerticalScrollBarVisibility="Visible"
                          AutoGenerateColumns="False" Background="White"
                          materialDesign:DataGridAssist.CellPadding="4 3 2 3" materialDesign:DataGridAssist.ColumnHeaderPadding="3"
                          CanUserAddRows="False" CanUserSortColumns="False">
                    <b:Interaction.Triggers>
                        <b:EventTrigger EventName="MouseDoubleClick">
                            <b:InvokeCommandAction Command="{Binding RemoveItemCommand}" 
                                 CommandParameter="{Binding SelectedItem, RelativeSource={RelativeSource AncestorType=DataGrid}}"/>
                        </b:EventTrigger>
                    </b:Interaction.Triggers>

                    <DataGrid.Columns>
                        <DataGridTextColumn Binding="{Binding RevitName}" IsReadOnly="True" FontSize="11"
                            ElementStyle="{StaticResource MaterialDesignDataGridTextColumnStyle}" Header="Имя спецификации" Width="350"/>
                        <DataGridTextColumn Binding="{Binding Title}" FontSize="11"
                            ElementStyle="{StaticResource MaterialDesignDataGridTextColumnStyle}" Header="Имя в ведомости" Width="400"/>
                        <DataGridTextColumn Binding="{Binding SheetNumber}" IsReadOnly="True" FontSize="11"
                            ElementStyle="{StaticResource MaterialDesignDataGridTextColumnStyle}" Header="Номер&#xa;листа" Width="50"/>
                    </DataGrid.Columns>
                </DataGrid>
            </GroupBox>

            <Button Content="Выполнить" Margin="5" Command="{Binding RunCommand}" Style="{StaticResource MaterialDesignPaperButton}"/>
        </StackPanel>
    </Grid>
</Window>
