<Window x:Class="BIMPlugins.ClashViewer.WPF.ClashViewerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:b="http://schemas.microsoft.com/xaml/behaviors"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:behaviors="clr-namespace:BIMPlugins.Windows.Behaviors;assembly=BIMPlugins.Windows"
        xmlns:converters="clr-namespace:BIMPlugins.Windows.Converters;assembly=BIMPlugins.Windows"
        xmlns:classes="clr-namespace:BIMPlugins.ClashViewer.Classes"
        xmlns:local="clr-namespace:BIMPlugins.ClashViewer.WPF"
        d:DataContext="{d:DesignInstance local:ClashViewerViewModel}"
        mc:Ignorable="d"
        Title="Просмотр коллизий" Height="800" Width="1100" WindowStartupLocation="CenterScreen" ResizeMode="NoResize">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <materialDesign:CustomColorTheme BaseTheme="Light" PrimaryColor="#f88518" SecondaryColor="#FF0052A5" />
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesign3.Defaults.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <Style TargetType="{x:Type Image}" x:Key="ScaleImage">
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="RenderTransform">
                            <Setter.Value>
                                <ScaleTransform ScaleX="3.5" ScaleY="3.5" CenterX="150" CenterY="0"/>
                            </Setter.Value>
                        </Setter>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <materialDesign:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
            <materialDesign:BooleanToVisibilityConverter x:Key="BooleanToVisibilityHiddenConverter" TrueValue="Visible" FalseValue="Hidden"/>
            <materialDesign:BooleanToVisibilityConverter x:Key="InverseBooleanToVisibilityConverter" TrueValue="Collapsed" FalseValue="Visible"/>
            <materialDesign:BooleanToVisibilityConverter x:Key="InverseBooleanToVisibilityHiddenConverter" TrueValue="Hidden" FalseValue="Visible"/>
            <materialDesign:NullableToVisibilityConverter x:Key="NullableToVisibilityConverter" />
            <materialDesign:InvertBooleanConverter x:Key="InvertBooleanConverter" />
            <converters:NullableToBoolConverter x:Key="NullableToBoolConverter"/>
            <converters:NumberToPercentConverter x:Key="NumberToPercentConverter"/>
            <converters:ImageOnLoadConverter x:Key="ImageOnLoadConverter"/>
            <converters:FilePathToFileNameConverter x:Key="FilePathToFileNameConverter"/>
        </ResourceDictionary>
    </Window.Resources>

    <Border Padding="3">
        <StackPanel>
            <StackPanel Orientation="Horizontal">
                <Button Content="Обзор" Padding="15 0" Style="{StaticResource MaterialDesignPaperButton}" Margin="5 0 5 3"
                        Command="{Binding SelectXMLFileCommand}" Height="25"/>
                <Button Width="25" Height="25" Padding="0" Margin="5 0 5 3" Command="{Binding SyncCommand}" IsEnabled="{Binding IsWorkFile}"
                        Style="{StaticResource MaterialDesignFlatButton}" ToolTip="Синхронизация">
                    <materialDesign:PackIcon Kind="Sync" Width="25" Height="25" Foreground="Black"/>
                </Button>
                <TextBox Text="{Binding XmlFilePath, Converter={StaticResource FilePathToFileNameConverter}}" IsReadOnly="True" Margin="0 0 0 3" Width="600"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         Height="25" Padding="5 0" materialDesign:HintAssist.Hint="Путь до файла отчета" materialDesign:HintAssist.IsFloating="False"/>

                <StackPanel>
                    <StackPanel  Orientation="Horizontal" Visibility="{Binding ReportDate, Converter={StaticResource NullableToVisibilityConverter}}" Margin="5 -3 5 0" VerticalAlignment="Center">
                        <TextBlock Text="Дата создания отчета: " FontSize="11.5"/>
                        <TextBlock Text="{Binding ReportDate}" FontSize="11.5"/>
                    </StackPanel>

                    <StackPanel  Orientation="Horizontal" Margin="5 0" Visibility="{Binding SyncTime, Converter={StaticResource NullableToVisibilityConverter}}" VerticalAlignment="Center">
                        <TextBlock Text="Время последней синхронизации: " FontSize="11.5"/>
                        <TextBlock Text="{Binding SyncTime}" FontSize="11.5"/>
                    </StackPanel>
                </StackPanel>
            </StackPanel>

            <Separator Margin="-3 2 -3 5" Background="#f88518"/>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="auto"/>
                    <ColumnDefinition />
                </Grid.ColumnDefinitions>

                <StackPanel IsEnabled="{Binding XmlFilePath, Converter={StaticResource NullableToBoolConverter}}">
                    <StackPanel Orientation="Horizontal">
                        <Image Source="/BIMPlugins.Windows;component/Resources/search-32.png" Height="15" Width="15" Margin="5 -10 5 0"/>
                        <TextBox Text="{Binding ClashTestFilter, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 Width="100" Margin="0 -4 5 10" FontSize="10" Padding="2 0"
                                 materialDesign:TextFieldAssist.HasClearButton="True" materialDesign:HintAssist.Hint="Поиск проверок" />
                    </StackPanel>
                    <ComboBox ItemsSource="{Binding FilteredClashTests}" SelectedItem="{Binding SelectedClashTest, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                              Margin="5 -5 5 5" Width="200"
                              HorizontalAlignment="Left" DisplayMemberPath="Name" Style="{StaticResource MaterialDesignOutlinedComboBox}"
                              materialDesign:HintAssist.IsFloating="False" Padding="5 3"
                              materialDesign:HintAssist.Hint="Список проверок" materialDesign:HintAssist.HelperText="Активная проверка" />
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <StackPanel IsEnabled="{Binding SelectedClashTest, Converter={StaticResource NullableToBoolConverter}}">
                        <Button Content="Очистить" Style="{StaticResource MaterialDesignFlatButton}"
                                HorizontalAlignment="Right" Padding="5 0" Height="25" FontSize="12" Margin="5 -4"
                                Command="{Binding ClearFilterCommand}" CommandParameter="{Binding SelectedStatusToFilter}"/>
                        <ComboBox Margin="5 0" Width="110" Style="{StaticResource MaterialDesignOutlinedComboBox}" Padding="5 3"
                                  materialDesign:HintAssist.Hint="– нет –" materialDesign:HintAssist.IsFloating="False"
                                  materialDesign:HintAssist.HelperText="Фильтр по статусу"
                                  ItemsSource="{Binding Statuses}" SelectedItem="{Binding SelectedStatusToFilter}"/>
                    </StackPanel>
                    
                    <StackPanel IsEnabled="{Binding SelectedClashTest, Converter={StaticResource NullableToBoolConverter}}">
                        <Button Content="Очистить" Style="{StaticResource MaterialDesignFlatButton}"
                                HorizontalAlignment="Right" Padding="5 0" Height="25" FontSize="12" Margin="5 -4"
                                Command="{Binding ClearFilterCommand}" CommandParameter="{Binding SelectedLevelToFilter}"/>
                        <ComboBox Margin="5 0" Width="110" Style="{StaticResource MaterialDesignOutlinedComboBox}" Padding="5 3"
                                  materialDesign:HintAssist.Hint="– нет –" materialDesign:HintAssist.IsFloating="False"
                                  materialDesign:HintAssist.HelperText="Фильтр по уровню"
                                  ItemsSource="{Binding Levels}" SelectedItem="{Binding SelectedLevelToFilter}"/>
                    </StackPanel>

                    <StackPanel IsEnabled="{Binding SelectedClashTest, Converter={StaticResource NullableToBoolConverter}}">
                        <Button Content="Очистить" Style="{StaticResource MaterialDesignFlatButton}" IsEnabled="{Binding IsLeftEqualRight, Converter={StaticResource InvertBooleanConverter}}"
                                HorizontalAlignment="Right" Padding="5 0" Height="25" FontSize="12" Margin="5 -4"
                                Command="{Binding ClearFilterCommand}" CommandParameter="{Binding SelectedSectionToFilter}"/>
                        <ComboBox Margin="5 0" Width="110" Style="{StaticResource MaterialDesignOutlinedComboBox}" Padding="5 3"
                                  materialDesign:HintAssist.Hint="– нет –" materialDesign:HintAssist.IsFloating="False"
                                  materialDesign:HintAssist.HelperText="Фильтр по ответств." IsEnabled="{Binding IsLeftEqualRight, Converter={StaticResource InvertBooleanConverter}}"
                                  ItemsSource="{Binding Sections}" SelectedItem="{Binding SelectedSectionToFilter}"/>
                    </StackPanel>

                    <StackPanel IsEnabled="{Binding SelectedClashTest, Converter={StaticResource NullableToBoolConverter}}">
                        <Button Content="Очистить" Style="{StaticResource MaterialDesignFlatButton}"
                                HorizontalAlignment="Right" Padding="5 0" Height="25" FontSize="12" Margin="5 -4"
                                Command="{Binding ClearFilterCommand}" CommandParameter="{Binding SelectedFamilyNameToFilter}"/>
                        <ComboBox Margin="5 0" Width="250" Style="{StaticResource MaterialDesignOutlinedComboBox}" Padding="5 3"
                                  materialDesign:HintAssist.Hint="– нет –" materialDesign:HintAssist.IsFloating="False"
                                  materialDesign:HintAssist.HelperText="Фильтр по имени семейства"
                                  ItemsSource="{Binding FamilyNames}" SelectedItem="{Binding SelectedFamilyNameToFilter}"/>
                    </StackPanel>
                    
                    <StackPanel IsEnabled="{Binding SelectedClashTest, Converter={StaticResource NullableToBoolConverter}}">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Top">
                            <CheckBox Content="Оба элемента" IsChecked="{Binding ContainsBothElements}" Padding="2 0" Margin="5 -4"/>
                            <Button Content="Очистить" Style="{StaticResource MaterialDesignFlatButton}"
                                    HorizontalAlignment="Right" Padding="5 0" Height="25" FontSize="12" Margin="37 -4"
                                    Command="{Binding ClearUserFilterCommand}"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <TextBox Text="{Binding SelectedUserFilterRules}" IsReadOnly="True" Margin="5 0" Width="200"
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}" TextWrapping="NoWrap"
                                     Height="24" Padding="5 0" materialDesign:HintAssist.Hint="– нет –" ToolTipService.InitialShowDelay="500"
                                     materialDesign:HintAssist.IsFloating="False" materialDesign:HintAssist.HelperText="Пользовательский фильтр">
                                <TextBox.ToolTip>
                                    <ToolTip Placement="Bottom">
                                        <TextBlock Text="{Binding SelectedUserFilterRules}" MaxWidth="450" TextWrapping="Wrap"/>
                                    </ToolTip>
                                </TextBox.ToolTip>
                            </TextBox>

                            <Button Width="28" Height="28" Padding="0" Margin="3 -4 0 0"
                                    Command="{Binding UserFilterCommand}" Style="{StaticResource MaterialDesignFlatButton}" ToolTip="Настройки фильтра">
                                <materialDesign:PackIcon Kind="FilterCogOutline" Width="28" Height="28" Foreground="#CC000000"/>
                            </Button>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </Grid>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="500"/>
                    <ColumnDefinition />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <Border BorderBrush="#f88518" BorderThickness="1" Margin="5 15 5 5">
                        <DataGrid ItemsSource="{Binding SelectedClashTest.FilteredClashResults, UpdateSourceTrigger=PropertyChanged}"
                                  AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False" 
                                  CanUserReorderColumns="False" Background="White" SelectionUnit="FullRow" SelectionMode="Extended"
                                  VirtualizingStackPanel.IsVirtualizing="True" CanUserSortColumns="False"
                                  VirtualizingStackPanel.VirtualizationMode="Recycling"
                                  EnableRowVirtualization="True" MinHeight="605" MaxHeight="605"
                                  EnableColumnVirtualization="False" behaviors:DataGridBehavior.SelectedItems="{Binding SelectedClashResults, Mode=TwoWay}"
                                  ScrollViewer.CanContentScroll="True" SelectedItem="{Binding SelectedClashResult, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                  materialDesign:DataGridAssist.CellPadding="4" materialDesign:DataGridAssist.ColumnHeaderPadding="3">
                            <DataGrid.Columns>
                                <!--Номер коллизии-->
                                <DataGridTextColumn Header="№" Binding="{Binding Number}" IsReadOnly="True">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock" BasedOn="{StaticResource MaterialDesignTextBlock}">
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                            <Setter Property="HorizontalAlignment" Value="Center"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                
                                <!--Имя коллизии-->
                                <DataGridTemplateColumn Header="Имя" IsReadOnly="True">
                                    <DataGridTemplateColumn.HeaderStyle>
                                        <Style TargetType="{x:Type DataGridColumnHeader}" BasedOn="{StaticResource MaterialDesignDataGridColumnHeader}">
                                            <Setter Property="HorizontalContentAlignment" Value="Center" />
                                        </Style>
                                    </DataGridTemplateColumn.HeaderStyle>

                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Name}" Foreground="{Binding Color}" VerticalAlignment="Center" HorizontalAlignment="Center" Padding="0"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <!--Статус коллизии-->
                                <DataGridTextColumn Header="Статус" Binding="{Binding Status}" Width="95" IsReadOnly="True">
                                    <DataGridTextColumn.HeaderStyle>
                                        <Style TargetType="{x:Type DataGridColumnHeader}" BasedOn="{StaticResource MaterialDesignDataGridColumnHeader}">
                                            <Setter Property="HorizontalContentAlignment" Value="Center" />
                                        </Style>
                                    </DataGridTextColumn.HeaderStyle>

                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock" BasedOn="{StaticResource MaterialDesignTextBlock}">
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                            <Setter Property="HorizontalAlignment" Value="Center"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>

                                <!--Комментарий-->
                                <DataGridTextColumn Header="Последний комментарий" Width="*" Binding="{Binding LastComment}" IsReadOnly="True">
                                    <DataGridTextColumn.HeaderStyle>
                                        <Style TargetType="{x:Type DataGridColumnHeader}" BasedOn="{StaticResource MaterialDesignDataGridColumnHeader}">
                                            <Setter Property="HorizontalContentAlignment" Value="Center" />
                                        </Style>
                                    </DataGridTextColumn.HeaderStyle>

                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock" BasedOn="{StaticResource MaterialDesignTextBlock}">
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                            <Setter Property="HorizontalAlignment" Value="Left"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>

                                <!--Кнопка выделения элементов-->
                                <DataGridTemplateColumn>
                                    <DataGridTemplateColumn.CellStyle>
                                        <Style TargetType="DataGridCell" BasedOn="{StaticResource MaterialDesignDataGridCell}">
                                            <Setter Property="Padding" Value="2 0"/>
                                        </Style>
                                    </DataGridTemplateColumn.CellStyle>
                                    
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Width="25" Height="25" Padding="0" VerticalAlignment="Center"
                                                    Style="{StaticResource MaterialDesignFlatButton}" ToolTip="Выделить элементы"
                                                    Command="{Binding DataContext.SelectElementsCommand,
                                                              RelativeSource={RelativeSource AncestorType=DataGrid}}">
                                                <materialDesign:PackIcon Kind="Target" Width="25" Height="25" Foreground="#99000000"/>
                                            </Button>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <!--Кнопка обрезки коллизии-->
                                <DataGridTemplateColumn>
                                    <DataGridTemplateColumn.CellStyle>
                                        <Style TargetType="DataGridCell" BasedOn="{StaticResource MaterialDesignDataGridCell}">
                                            <Setter Property="Padding" Value="2 0"/>
                                        </Style>
                                    </DataGridTemplateColumn.CellStyle>
                                    
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Height="25" Width="25" Padding="0" VerticalAlignment="Center"
                                                    Style="{StaticResource MaterialDesignFlatButton}" ToolTip="Показать элементы"
                                                    Command="{Binding DataContext.SectionBoxCommand,
                                                              RelativeSource={RelativeSource AncestorType=DataGrid}}">
                                                <Image Source="/BIMPlugins.Windows;component/Resources/sectionBox-32.png" Width="20" Height="20"/>
                                            </Button>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <!--Кнопка проверки на пересечение-->
                                <DataGridTemplateColumn>
                                    <DataGridTemplateColumn.CellStyle>
                                        <Style TargetType="DataGridCell" BasedOn="{StaticResource MaterialDesignDataGridCell}">
                                            <Setter Property="Padding" Value="2 0"/>
                                        </Style>
                                    </DataGridTemplateColumn.CellStyle>

                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Height="25" Width="25" Padding="0" VerticalAlignment="Center"
                                                    Style="{StaticResource MaterialDesignFlatButton}" ToolTip="Проверить пересечение"
                                                    Command="{Binding DataContext.CheckIntersectionCommand,
                                                              RelativeSource={RelativeSource AncestorType=DataGrid}}">
                                                <materialDesign:PackIcon Kind="VectorIntersection" Width="25" Height="25" Foreground="#99000000"/>
                                            </Button>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="auto"/>
                            <ColumnDefinition Width="auto"/>
                            <ColumnDefinition />
                        </Grid.ColumnDefinitions>

                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Прогресс:" Margin="5" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            <Button Margin="5" Background="WhiteSmoke" BorderBrush="WhiteSmoke" Foreground="Black" Height="30" Width="30"
                                    Content="{Binding ProgressStatus, Converter={StaticResource NumberToPercentConverter}}" 
                                    materialDesign:ButtonProgressAssist.IsIndicatorVisible="True" ToolTip="Процент отработанных конфликтов"
                                    materialDesign:ButtonProgressAssist.Value="{Binding ProgressStatus}" ToolTipService.Placement="Right"
                                    materialDesign:ButtonProgressAssist.IndicatorBackground="#ffcc80"  ToolTipService.InitialShowDelay="200"
                                    Style="{StaticResource MaterialDesignFloatingActionSecondaryButton}"/>
                        </StackPanel>

                        <TextBox Grid.Column="1" Text="{Binding Padding, Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"
                                 Height="auto" VerticalAlignment="Top" Margin="15 10 0 0"
                                 Width="93" Padding="2 0" materialDesign:HintAssist.IsFloating="True"
                                 Visibility="{Binding SelectedClashResult, Converter={StaticResource NullableToVisibilityConverter}}"
                                 materialDesign:HintAssist.Hint="Габариты 3D-обрезки" materialDesign:TextFieldAssist.SuffixText="мм"/>

                        <CheckBox Grid.Column="3" Content="Изолировать при 3D-обрезке" Padding="2 0" Margin="10 0" VerticalAlignment="Top"
                                  IsChecked="{Binding IsolateElements}" Visibility="{Binding SelectedClashResult, Converter={StaticResource NullableToVisibilityConverter}}"/>
                    </Grid>
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="5 15 5 5"
                            Visibility="{Binding SelectedClashResult, Converter={StaticResource NullableToVisibilityConverter}}">
                    <GroupBox Padding="0" Panel.ZIndex="1">
                        <GroupBox.Header>
                            <TextBlock Text="Информация об конфликте" FontWeight="SemiBold" />
                        </GroupBox.Header>
                        <StackPanel>
                            <Grid Panel.ZIndex="1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition />
                                    <ColumnDefinition Width="auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Имя:" FontWeight="DemiBold" Margin="5" VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding SelectedClashResult.Name}" Margin="0 5" VerticalAlignment="Center"/>

                                        <StackPanel Orientation="Horizontal" Margin="10 0 0 0"
                                                    Visibility="{Binding SelectedClashResult.CreatedDate, Converter={StaticResource NullableToVisibilityConverter}}">
                                            <TextBlock Text="Найден:" FontWeight="DemiBold" Margin="5" VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding SelectedClashResult.CreatedDate}" Margin="0 5" VerticalAlignment="Center"/>
                                        </StackPanel>

                                        <StackPanel Orientation="Horizontal" Margin="10 0 0 0"
                                                    Visibility="{Binding SelectedClashResult.LevelName, Converter={StaticResource NullableToVisibilityConverter}}">
                                            <TextBlock Text="Уровень:" FontWeight="DemiBold" Margin="5" VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding SelectedClashResult.LevelName}" Margin="0 5" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </StackPanel>

                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Top">
                                        <TextBlock Text="Статус:" FontWeight="DemiBold" Margin="5" VerticalAlignment="Center"/>
                                        <Button Content="В работу" Margin="5" Style="{StaticResource MaterialDesignPaperButton}"
                                                Padding="5 0" FontSize="12" Height="25"
                                                Visibility="{Binding SelectedClashResult.IsActive, Converter={StaticResource InverseBooleanToVisibilityConverter}}"
                                                Command="{Binding SetStatusCommand}" CommandParameter="Активная"/>
                                        <Button Content="Исправлен" Margin="5" Style="{StaticResource MaterialDesignPaperButton}"
                                                Padding="5 0" FontSize="12" Height="25"
                                                Visibility="{Binding SelectedClashResult.IsActive, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                Command="{Binding SetStatusCommand}" CommandParameter="Исправленная"/>
                                        <Button Content="Не коллизия" Margin="5" Style="{StaticResource MaterialDesignPaperButton}"
                                                Padding="5 0" FontSize="12" Height="25"
                                                Visibility="{Binding SelectedClashResult.IsActive, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                Command="{Binding SetStatusCommand}" CommandParameter="Не коллизия"/>
                                    </StackPanel>

                                    <StackPanel Orientation="Horizontal" Visibility="{Binding IsLeftEqualRight, Converter={StaticResource InverseBooleanToVisibilityHiddenConverter}}">
                                        <TextBlock Text="Ответственный:" FontWeight="DemiBold" Margin="5" VerticalAlignment="Center"/>
                                        <Rectangle Fill="#FFFF3F3F" Width="10" Height="10" RadiusX="5" RadiusY="5"/>
                                        <Button Content="{Binding LeftSection}" Margin="5" Style="{StaticResource MaterialDesignPaperButton}"
                                                Width="60" FontSize="12" Height="25" Padding="0"
                                                IsEnabled="{Binding SelectedClashResult.IsLeftSelected, Converter={StaticResource InvertBooleanConverter}}"
                                                Command="{Binding AssignRoleCommand}" CommandParameter="{Binding LeftSection}"/>
                                        <Rectangle Fill="#FF2CB300" Width="10" Height="10" RadiusX="5" RadiusY="5" Margin="5 0 0 0"/>
                                        <Button Content="{Binding RightSection}" Margin="5" Style="{StaticResource MaterialDesignPaperButton}"
                                                Width="60" FontSize="12" Height="25" Padding="0" IsEnabled="{Binding SelectedClashResult.IsLeftSelected}"
                                                Command="{Binding AssignRoleCommand}" CommandParameter="{Binding RightSection}"/>
                                    </StackPanel>

                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Комментарий:" FontWeight="DemiBold" Margin="5" VerticalAlignment="Center"/>
                                        <TextBox Text="{Binding NewCommentText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                 Margin="0 5" Padding="5 3" Width="280"
                                                 Style="{StaticResource MaterialDesignOutlinedTextBox}" materialDesign:TextFieldAssist.HasClearButton="True"
                                                 materialDesign:HintAssist.Hint="Добавить новый комментарий" materialDesign:HintAssist.IsFloating="False"
                                                 ToolTipService.InitialShowDelay="300" ToolTipService.BetweenShowDelay="5">
                                            <b:Interaction.Triggers>
                                                <b:EventTrigger EventName="KeyDown">
                                                    <b:InvokeCommandAction Command="{Binding ExecuteEnterKeyCommand}"
                                                                           PassEventArgsToCommand="True"/>
                                                </b:EventTrigger>
                                            </b:Interaction.Triggers>

                                            <TextBox.ToolTip>
                                                <ToolTip Placement="Bottom">
                                                    <TextBlock Text="{Binding NewCommentText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                               MaxWidth="350" TextWrapping="Wrap"/>
                                                </ToolTip>
                                            </TextBox.ToolTip>
                                        </TextBox>
                                        <Button Width="22" Height="22" Padding="0" Margin="5 0"
                                                Command="{Binding WriteNewCommentCommand}"
                                                Style="{StaticResource MaterialDesignFlatButton}" ToolTip="Добавить комментарий">
                                            <materialDesign:PackIcon Kind="Send" Width="22" Height="22" Foreground="Black"/>
                                        </Button>
                                    </StackPanel>
                                </StackPanel>

                                <Image Grid.Column="1" Source="{Binding SelectedClashResult.ImagePath, Converter={StaticResource ImageOnLoadConverter}}" RenderOptions.BitmapScalingMode="HighQuality"
                                       HorizontalAlignment="Right"
                                       Style="{StaticResource ScaleImage}" Width="150" Height="120" Margin="5" Stretch="Fill" />
                            </Grid>

                            <Separator BorderThickness="1" BorderBrush="#f88518"/>

                            <Grid Panel.ZIndex="0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="auto" />
                                    <ColumnDefinition />
                                    <ColumnDefinition />
                                </Grid.ColumnDefinitions>

                                <Grid.RowDefinitions>
                                    <RowDefinition Height="auto"/>
                                    <RowDefinition Height="auto"/>
                                    <RowDefinition Height="auto"/>
                                    <RowDefinition MaxHeight="45"/>
                                    <RowDefinition MaxHeight="45"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Column="1" Text="Элемент 1" FontWeight="DemiBold" Margin="5 0"
                                           VerticalAlignment="Top" HorizontalAlignment="Left"/>
                                <TextBlock Grid.Column="2" Text="Элемент 2" FontWeight="DemiBold"  Margin="5 0"
                                           VerticalAlignment="Top" HorizontalAlignment="Left"/>

                                <TextBlock Grid.Row="1" Text="Документ:" FontWeight="DemiBold" Margin="5" VerticalAlignment="Top"/>
                                <TextBlock Grid.Row="2" Text="Id элемента:" FontWeight="DemiBold" Margin="5" VerticalAlignment="Top"/>
                                <TextBlock Grid.Row="3" Text="Имя семейства:" FontWeight="DemiBold" Margin="5" VerticalAlignment="Top"/>
                                <TextBlock Grid.Row="4" Text="Имя типа:" FontWeight="DemiBold" Margin="5" VerticalAlignment="Top"/>

                                <TextBlock Grid.Column="1" Grid.Row="1" Text="{Binding SelectedClashResult.ClashObjects[0].DocName}" Margin="5"
                                           ToolTipService.InitialShowDelay="300">
                                    <TextBlock.ToolTip>
                                        <ToolTip Placement="Bottom">
                                            <TextBlock Text="{Binding SelectedClashResult.ClashObjects[0].DocName}" MaxWidth="230" TextWrapping="Wrap"/>
                                        </ToolTip>
                                    </TextBlock.ToolTip>
                                </TextBlock>
                                <StackPanel Grid.Column="1" Grid.Row="2" Orientation="Horizontal">
                                    <TextBlock Grid.Column="1" Grid.Row="2" Text="{Binding SelectedClashResult.ClashObjects[0].Id}" Margin="5" />
                                    <Button Width="20" Height="20" Padding="0" Margin="10 0"
                                            Command="{Binding CopyIdCommand}" CommandParameter="{Binding SelectedClashResult.ClashObjects[0]}" 
                                            Style="{StaticResource MaterialDesignFlatButton}" ToolTip="Копировать">
                                        <materialDesign:PackIcon Kind="ContentCopy" Width="20" Height="20" Foreground="Black"/>
                                    </Button>
                                </StackPanel>
                                <TextBlock Grid.Column="1" Grid.Row="3" Text="{Binding SelectedClashResult.ClashObjects[0].FamilyName}" Margin="5"
                                           ToolTipService.InitialShowDelay="300">
                                    <TextBlock.ToolTip>
                                        <ToolTip Placement="Bottom">
                                            <TextBlock Text="{Binding SelectedClashResult.ClashObjects[0].FamilyName}" MaxWidth="230" TextWrapping="Wrap"/>
                                        </ToolTip>
                                    </TextBlock.ToolTip>
                                </TextBlock>
                                <TextBlock Grid.Column="1" Grid.Row="4" Text="{Binding SelectedClashResult.ClashObjects[0].Type}" Margin="5"
                                           ToolTipService.InitialShowDelay="300">
                                    <TextBlock.ToolTip>
                                        <ToolTip Placement="Bottom">
                                            <TextBlock Text="{Binding SelectedClashResult.ClashObjects[0].Type}" MaxWidth="230" TextWrapping="Wrap"/>
                                        </ToolTip>
                                    </TextBlock.ToolTip>
                                </TextBlock>

                                <TextBlock Grid.Column="2" Grid.Row="1" Text="{Binding SelectedClashResult.ClashObjects[1].DocName}" Margin="5"
                                           ToolTipService.InitialShowDelay="300">
                                    <TextBlock.ToolTip>
                                        <ToolTip Placement="Bottom">
                                            <TextBlock Text="{Binding SelectedClashResult.ClashObjects[1].DocName}" MaxWidth="230" TextWrapping="Wrap"/>
                                        </ToolTip>
                                    </TextBlock.ToolTip>
                                </TextBlock>
                                <StackPanel Grid.Column="2" Grid.Row="2" Orientation="Horizontal">
                                    <TextBlock Grid.Column="2" Grid.Row="2" Text="{Binding SelectedClashResult.ClashObjects[1].Id}" Margin="5" />
                                    <Button Width="20" Height="20" Padding="0"  Margin="10 0"
                                            Command="{Binding CopyIdCommand}" CommandParameter="{Binding SelectedClashResult.ClashObjects[1]}"
                                            Style="{StaticResource MaterialDesignFlatButton}" ToolTip="Копировать">
                                        <materialDesign:PackIcon Kind="ContentCopy" Width="20" Height="20" Foreground="Black"/>
                                    </Button>
                                </StackPanel>
                                <TextBlock Grid.Column="2" Grid.Row="3" Text="{Binding SelectedClashResult.ClashObjects[1].FamilyName}" Margin="5"
                                           ToolTipService.InitialShowDelay="300">
                                    <TextBlock.ToolTip>
                                        <ToolTip Placement="Bottom">
                                            <TextBlock Text="{Binding SelectedClashResult.ClashObjects[1].FamilyName}" MaxWidth="230" TextWrapping="Wrap"/>
                                        </ToolTip>
                                    </TextBlock.ToolTip>
                                </TextBlock>
                                <TextBlock Grid.Column="2" Grid.Row="4" Text="{Binding SelectedClashResult.ClashObjects[1].Type}" Margin="5"
                                           ToolTipService.InitialShowDelay="300">
                                    <TextBlock.ToolTip>
                                        <ToolTip Placement="Bottom">
                                            <TextBlock Text="{Binding SelectedClashResult.ClashObjects[1].Type}" MaxWidth="230" TextWrapping="Wrap"/>
                                        </ToolTip>
                                    </TextBlock.ToolTip>
                                </TextBlock>
                            </Grid>
                        </StackPanel>
                    </GroupBox>

                    <GroupBox Padding="0" Panel.ZIndex="0"
                              Visibility="{Binding SelectedClashResult.HasHistoryItems, Converter={StaticResource BooleanToVisibilityHiddenConverter}}">
                        <GroupBox.Header>
                            <TextBlock Text="История изменений" FontWeight="DemiBold" />
                        </GroupBox.Header>

                        <ItemsControl ItemsSource="{Binding SelectedClashResult.HistoryItems}" MaxHeight="289.8" Padding="0">
                            <ItemsControl.Template>
                                <ControlTemplate TargetType="ItemsControl">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </ControlTemplate>
                            </ItemsControl.Template>

                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type classes:HistoryItem}">
                                    <Border Padding="5" BorderBrush="{DynamicResource MaterialDesignDivider}" BorderThickness="0,0,0,1">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="auto"/>
                                                <ColumnDefinition />
                                            </Grid.ColumnDefinitions>
                                            <materialDesign:Chip Style="{StaticResource MaterialDesignOutlineChip}" BorderBrush="#f88518"
                                                                 Width="33" IconBackground="Transparent">
                                                <materialDesign:Chip.Icon>
                                                    <TextBlock Text="{Binding ChipIcon}" TextAlignment="Center" FontWeight="SemiBold"/>
                                                </materialDesign:Chip.Icon>
                                            </materialDesign:Chip>
                                            <StackPanel Grid.Column="1" Margin="5,0,0,0">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition />
                                                        <ColumnDefinition />
                                                    </Grid.ColumnDefinitions>

                                                    <TextBlock Text="{Binding Author}" HorizontalAlignment="Left"/>
                                                    <TextBlock Grid.Column="1" Text="{Binding Date}" HorizontalAlignment="Right" Margin="0 0 5 0"/>
                                                </Grid>
                                                
                                                <Border BorderBrush="{DynamicResource MaterialDesignShadowBrush}" BorderThickness="1"
                                                        CornerRadius="5" Margin="0 3 0 0">
                                                    <TextBlock Text="{Binding Comment}" HorizontalAlignment="Left" MaxHeight="33" Margin="5 3">
                                                        <TextBlock.ToolTip>
                                                            <ToolTip Placement="Bottom">
                                                                <TextBlock Text="{Binding Comment}" MaxWidth="550" TextWrapping="Wrap"/>
                                                            </ToolTip>
                                                        </TextBlock.ToolTip>
                                                    </TextBlock>
                                                </Border>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </GroupBox>
                </StackPanel>
            </Grid>
        </StackPanel>
    </Border>
</Window>
